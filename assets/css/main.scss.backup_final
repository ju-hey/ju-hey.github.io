<!-- THE ULTIMATE HEADER SCRIPT -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const masthead = document.querySelector('.masthead');
  if (!masthead) return;

  let lastScrollY = window.scrollY || 0;
  let hideTimer = null;
  const revealZone = 34;
  const topLock = 50;
  const idleDelay = 3000;

  const showHeader = () => {
    masthead.classList.remove('is-hidden');
  };

  const hideHeader = () => {
    if (window.scrollY > topLock && !masthead.matches(':hover')) {
      masthead.classList.add('is-hidden');
    }
  };

  const clearHideTimer = () => {
    clearTimeout(hideTimer);
    hideTimer = null;
  };

  const scheduleIdleHide = () => {
    clearHideTimer();
    if (window.scrollY <= topLock) return;
    hideTimer = setTimeout(() => {
      hideHeader();
    }, idleDelay);
  };

  window.addEventListener('scroll', () => {
    const currentY = window.scrollY || 0;
    const delta = currentY - lastScrollY;

    if (currentY <= topLock) {
      showHeader();
      clearHideTimer();
    } else if (delta > 4) {
      hideHeader();
      clearHideTimer();
    } else if (delta < -4) {
      showHeader();
      scheduleIdleHide();
    } else {
      scheduleIdleHide();
    }

    lastScrollY = currentY;
  }, { passive: true });

  document.addEventListener('mousemove', (e) => {
    if (e.clientY <= revealZone) {
      showHeader();
      scheduleIdleHide();
    }
  });

  document.addEventListener('pointerdown', (e) => {
    if (e.clientY <= revealZone) {
      showHeader();
      scheduleIdleHide();
    }
  }, { passive: true });

  masthead.addEventListener('mouseenter', () => {
    clearHideTimer();
    showHeader();
  });
  masthead.addEventListener('mouseleave', () => {
    scheduleIdleHide();
  });

  scheduleIdleHide();
});
</script>
<!-- /THE ULTIMATE HEADER SCRIPT -->


