    <button class="post-like-btn" data-like-post="assets/css/main.scss.backup_final" aria-label="Like this post">
      <svg class="like-heart" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="like-count"></span>
    </button>
  

  
</div>

<style>
  /* ── Actions bar: like (left) + share (right) ── */
  .post-actions-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    clear: both;
    padding-top: 1.5em;
  }

  /* ── Like button ── */
  .post-like-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.38rem 0.6rem;
    border: 2px solid #e2e8f0;
    border-radius: 999px;
    background: #fff;
    color: #94a3b8;
    font-size: 0.7rem;
    line-height: 1;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }
  .post-like-btn.has-count { padding: 0.3rem 0.6rem; }
  .post-like-btn:hover { border-color: #f87171; color: #f87171; }
  .post-like-btn.liked { border-color: #f87171; color: #ef4444; }
  .post-like-btn .like-heart { width: 16px; height: 16px; transition: transform 0.2s; }
  .post-like-btn .like-count { display: inline-block; line-height: 1; font-variant-numeric: tabular-nums; }
  .post-like-btn:active .like-heart { transform: scale(1.3); }
  .like-count:empty { display: none; }

  /* ── Share trigger button ── */
  .post-share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 2px solid #e2e8f0;
    border-radius: 999px;
    background: #fff;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s;
  }
  .post-share-btn:hover { border-color: #64748b; color: #475569; }

  /* ── Share modal overlay ── */
  .share-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.4);
    align-items: center;
    justify-content: center;
  }
  .share-modal-overlay.is-visible { display: flex; }

  /* ── Share modal box ── */
  .share-modal {
    position: relative;
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem 1.75rem 1.25rem;
    width: 320px;
    max-width: 90vw;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    animation: share-modal-in 0.2s ease-out;
  }
  @keyframes share-modal-in {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .share-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.4rem;
    color: #94a3b8;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
  }
  .share-modal__close:hover { color: #334155; }
  .share-modal__title {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: #1e293b;
  }
  .share-modal__links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .share-modal__link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #334155;
    text-decoration: none;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    cursor: pointer;
    transition: all 0.15s;
  }
  .share-modal__link:hover { background: #f1f5f9; border-color: #cbd5e1; }
  .share-modal__link i,
  .share-modal__link svg { flex-shrink: 0; font-size: 1.1rem; }
  .share-modal__link--x:hover { color: #000; }
  .share-modal__link--facebook:hover { color: #1877f2; }
  .share-modal__link--linkedin:hover { color: #0a66c2; }
  .share-modal__link--bluesky:hover { color: #0085ff; }
  .share-modal__link--copy { font-family: inherit; }
  .share-modal__link--copy:hover { color: #16a34a; }
</style>


      


