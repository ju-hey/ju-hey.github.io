<script>
document.addEventListener('DOMContentLoaded', function() {
  const header = document.querySelector('.page__header');
  const title = header ? header.querySelector('.page__title') : null;
  if (!header || !title) return;

  const maybeScrollFromCardEntry = () => {
    let fromPostCard = false;
    try {
      fromPostCard = sessionStorage.getItem('juhey:post-card-nav') === '1';
      sessionStorage.removeItem('juhey:post-card-nav');
    } catch (_) {
      fromPostCard = false;
    }
    if (!fromPostCard) return;

    const sidebar = document.querySelector('.single-main-grid > .sidebar');
    if (!sidebar) return;

    const sidebarTop = sidebar.getBoundingClientRect().top;
    const headerTop = header.getBoundingClientRect().top;
    const isSidebarStackedOnTop = headerTop - sidebarTop > 80;
    if (!isSidebarStackedOnTop) return;

    const topPadding = 12;
    const targetTop = Math.max(0, window.pageYOffset + header.getBoundingClientRect().top - topPadding);
    window.scrollTo({ top: targetTop, behavior: 'auto' });
  };

  const syncHeaderHeight = () => {
    header.style.setProperty('--page-header-extra-height', '0px');

    const computed = window.getComputedStyle(title);
    const lineHeight = parseFloat(computed.lineHeight);
    if (!lineHeight || Number.isNaN(lineHeight)) return;

    const titleHeight = title.getBoundingClientRect().height;
    const lines = Math.max(1, Math.round(titleHeight / lineHeight));
    const extraLines = Math.max(0, lines - 1);
    const extraHeight = extraLines * lineHeight;

    header.style.setProperty('--page-header-extra-height', `${extraHeight}px`);
  };

  syncHeaderHeight();
  maybeScrollFromCardEntry();
  window.addEventListener('resize', syncHeaderHeight, { passive: true });

  if ('ResizeObserver' in window) {
    const observer = new ResizeObserver(syncHeaderHeight);
    observer.observe(title);
  }
});
</script>



      
